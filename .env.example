# Copy this to .env and fill in your values.
# .env is git-ignored and will never be committed.
#
# Add one line per API key. The variable NAME is what you register
# with KeyManager — the value is your actual FMP key.

FMP_KEY_WORK=your_work_fmp_key_here
FMP_KEY_PERSONAL=your_personal_fmp_key_here

# Optional: used as a direct fallback when no alias is given
# FMP_API_KEY=your_default_key_here
